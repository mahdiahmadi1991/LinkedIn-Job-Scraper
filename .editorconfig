root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.cs]
indent_size = 4

[*.{csproj,props,targets,sln,slnx}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.cshtml]
indent_size = 4

[src/LinkedIn.JobScraper.Web/Persistence/Migrations/*.cs]
dotnet_diagnostic.CA1861.severity = none
