@model LinkedInSearchSettingsPageViewModel

@{
    ViewData["Title"] = "Search Settings";
    var alertSeverity = Model.StatusSucceeded ? "success" : "warning";
}

<div class="page-shell">
    <section class="page-hero">
        <div class="section-label mb-2">Fetch Definition</div>
        <h1 class="hero-title h2">LinkedIn Search Settings</h1>
        <p class="hero-lead">
            Configure the exact LinkedIn search that powers <strong>Fetch &amp; Score</strong>. These settings define which jobs get pulled into the dashboard.
        </p>
    </section>

    <div class="alert alert-@alertSeverity mb-0 @((string.IsNullOrWhiteSpace(Model.StatusMessage) ? "d-none" : string.Empty))"
         role="alert"
         data-search-settings-status>
        @Model.StatusMessage
    </div>

    <section class="row g-4">
        <div class="col-12 col-xl-8">
            <div class="card app-panel">
                <div class="card-body app-panel-body">
                    <form asp-action="Save" method="post" class="d-flex flex-column gap-4" id="search-settings-form">
                        @Html.AntiForgeryToken()

                        <input asp-for="ConcurrencyToken" type="hidden" />
                        <input asp-for="LocationDisplayName" type="hidden" />
                        <input asp-for="LocationGeoId" type="hidden" />

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="ProfileName" class="form-label"></label>
                                <input asp-for="ProfileName" class="form-control" />
                                <span asp-validation-for="ProfileName" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Keywords" class="form-label"></label>
                                <input asp-for="Keywords" class="form-control" placeholder="C#, .NET, backend, company, title" />
                                <span asp-validation-for="Keywords" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="LocationInput" class="form-label"></label>
                                <div class="d-flex flex-column flex-md-row gap-2">
                                    <input asp-for="LocationInput" class="form-control" placeholder="Limassol, Cyprus" />
                                    <button type="submit"
                                            class="btn btn-outline-primary"
                                            formaction="@Url.Action("SearchLocation")"
                                            formmethod="post"
                                            data-search-settings-location-button>
                                        Find Locations
                                    </button>
                                </div>
                                <span asp-validation-for="LocationInput" class="text-danger small"></span>
                                @if (!string.IsNullOrWhiteSpace(Model.LocationDisplayName))
                                {
                                    <div class="small text-muted mt-2">
                                        Selected LinkedIn location: <strong>@Model.LocationDisplayName</strong>
                                        <span class="ms-1">(@Model.LocationGeoId)</span>
                                    </div>
                                }
                            </div>
                        </div>

                        @if (Model.LocationSuggestions.Count > 0)
                        {
                            <div class="selection-card">
                                <div class="section-label mb-2">LinkedIn Location Suggestions</div>
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var suggestion in Model.LocationSuggestions)
                                    {
                                        var isSelected = string.Equals(Model.LocationGeoId, suggestion.GeoId, StringComparison.Ordinal);
                                        <button type="button"
                                                class="btn @(isSelected ? "btn-primary" : "btn-outline-secondary") text-start"
                                                data-location-select
                                                data-geo-id="@suggestion.GeoId"
                                                data-display-name="@suggestion.DisplayName">
                                            <span class="fw-semibold">@suggestion.DisplayName</span>
                                            <span class="small ms-2">@suggestion.GeoId</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        }

                        <div class="form-check form-switch">
                            <input asp-for="EasyApply" class="form-check-input" />
                            <label asp-for="EasyApply" class="form-check-label"></label>
                        </div>

                        <div class="row g-4">
                            <div class="col-12 col-lg-6">
                                <div class="selection-card selection-card-tight h-100">
                                    <div class="section-label mb-2">Remote</div>
                                    <div class="d-flex flex-column gap-2">
                                        @foreach (var option in LinkedInSearchSettingsPageViewModel.WorkplaceTypeOptions)
                                        {
                                            var isChecked = Model.WorkplaceTypeCodes.Contains(option.Code, StringComparer.OrdinalIgnoreCase);
                                            <label class="form-check">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       name="WorkplaceTypeCodes"
                                                       value="@option.Code"
                                                       checked="@isChecked" />
                                                <span class="form-check-label">@option.Label</span>
                                            </label>
                                        }
                                    </div>
                                    <span asp-validation-for="WorkplaceTypeCodes" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-12 col-lg-6">
                                <div class="selection-card selection-card-tight h-100">
                                    <div class="section-label mb-2">Job Type</div>
                                    <div class="d-flex flex-column gap-2">
                                        @foreach (var option in LinkedInSearchSettingsPageViewModel.JobTypeOptions)
                                        {
                                            var isChecked = Model.JobTypeCodes.Contains(option.Code, StringComparer.OrdinalIgnoreCase);
                                            <label class="form-check">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       name="JobTypeCodes"
                                                       value="@option.Code"
                                                       checked="@isChecked" />
                                                <span class="form-check-label">@option.Label</span>
                                            </label>
                                        }
                                    </div>
                                    <span asp-validation-for="JobTypeCodes" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary" data-search-settings-save-button>Save Search Settings</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="card h-100 app-panel">
                <div class="card-body app-panel-body d-flex flex-column gap-3">
                    <div>
                        <div class="section-label mb-2">What this controls</div>
                        <h2 class="h5">What this controls</h2>
                        <p class="small text-muted mb-0">
                            These filters determine the exact LinkedIn search request used by the next <strong>Fetch &amp; Score</strong> run.
                        </p>
                    </div>
                    <div class="small">
                        <div><strong>Keywords:</strong> title, skill, or company text search</div>
                        <div><strong>Location:</strong> resolved to a LinkedIn geoId through typeahead</div>
                        <div><strong>Remote:</strong> multi-select workplace type filter</div>
                        <div><strong>Job Type:</strong> multi-select employment filter</div>
                        <div><strong>Easy Apply:</strong> limits fetches to LinkedIn easy apply listings</div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts
{
    <script>
        (() => {
            const form = document.getElementById("search-settings-form");
            if (!form) {
                return;
            }

            const statusAlert = form.closest(".page-shell")?.querySelector("[data-search-settings-status]");
            const saveButton = form.querySelector("[data-search-settings-save-button]");
            const concurrencyTokenInput = form.querySelector('input[name="ConcurrencyToken"]');
            const geoIdInput = form.querySelector('input[name="LocationGeoId"]');
            const displayNameInput = form.querySelector('input[name="LocationDisplayName"]');
            const locationInput = form.querySelector('input[name="LocationInput"]');
            const suggestionButtons = form.querySelectorAll("[data-location-select]");

            if (!statusAlert || !saveButton) {
                return;
            }

            const setStatus = (message, success) => {
                statusAlert.textContent = message;
                statusAlert.classList.remove("d-none", "alert-success", "alert-warning");
                statusAlert.classList.add(success ? "alert-success" : "alert-warning");
            };

            const tryReadProblem = async (response) => {
                const contentType = response.headers.get("Content-Type") || "";
                if (!contentType.includes("application/problem+json") && !contentType.includes("application/json")) {
                    return null;
                }

                try {
                    return await response.json();
                } catch {
                    return null;
                }
            };

            locationInput?.addEventListener("input", () => {
                if (geoIdInput) {
                    geoIdInput.value = "";
                }

                if (displayNameInput) {
                    displayNameInput.value = "";
                }
            });

            suggestionButtons.forEach((button) => {
                button.addEventListener("click", () => {
                    const geoId = button.getAttribute("data-geo-id");
                    const displayName = button.getAttribute("data-display-name");

                    if (geoIdInput) {
                        geoIdInput.value = geoId ?? "";
                    }

                    if (displayNameInput) {
                        displayNameInput.value = displayName ?? "";
                    }

                    if (locationInput && displayName) {
                        locationInput.value = displayName;
                    }

                    suggestionButtons.forEach((currentButton) => {
                        currentButton.classList.remove("btn-primary");
                        currentButton.classList.remove("btn-outline-primary");
                        currentButton.classList.add("btn-outline-secondary");
                    });

                    button.classList.remove("btn-outline-secondary");
                    button.classList.add("btn-primary");
                });
            });

            form.addEventListener("submit", async (event) => {
                const submitter = event.submitter;
                if (submitter && submitter.hasAttribute("data-search-settings-location-button")) {
                    return;
                }

                event.preventDefault();

                const idleText = saveButton.textContent;
                saveButton.disabled = true;
                saveButton.textContent = "Saving...";

                try {
                    const response = await fetch(form.action, {
                        method: "POST",
                        body: new FormData(form),
                        headers: {
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        credentials: "same-origin"
                    });

                    const payload = await tryReadProblem(response);

                    if (!response.ok) {
                        setStatus(payload?.detail || payload?.title || "Settings save failed.", false);
                        return;
                    }

                    if (!payload?.success) {
                        setStatus("Settings save did not return a usable response.", false);
                        return;
                    }

                    if (concurrencyTokenInput && payload.concurrencyToken) {
                        concurrencyTokenInput.value = payload.concurrencyToken;
                    }

                    setStatus(payload.message || "Search settings were saved.", true);
                } catch {
                    setStatus("Settings save failed.", false);
                } finally {
                    saveButton.disabled = false;
                    saveButton.textContent = idleText;
                }
            });
        })();
    </script>
}
