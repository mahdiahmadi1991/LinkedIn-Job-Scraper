@model AiSettingsPageViewModel

@{
    ViewData["Title"] = "AI Settings";
    var alertSeverity = Model.StatusSucceeded ? "success" : "warning";
}

<div class="page-shell">
    <section class="page-hero">
        <div class="section-label mb-2">Scoring Behavior</div>
        <h1 class="hero-title h2">AI Settings</h1>
        <p class="hero-lead">Adjust the behavioral profile used when scoring LinkedIn jobs. API keys stay in configuration, but scoring preferences live here.</p>
    </section>

    <div class="alert alert-@alertSeverity mb-0 @((string.IsNullOrWhiteSpace(Model.StatusMessage) ? "d-none" : string.Empty))"
         role="alert"
         data-ai-settings-status>
        @Model.StatusMessage
    </div>

    <section class="row g-4">
        <div class="col-12 col-xl-8">
            <div class="card app-panel">
                <div class="card-body app-panel-body">
                    <form asp-action="Save" method="post" class="d-flex flex-column gap-3" data-ai-settings-form>
                        @Html.AntiForgeryToken()
                        <input asp-for="ConcurrencyToken" type="hidden" />
                        <div>
                            <label asp-for="ProfileName" class="form-label"></label>
                            <input asp-for="ProfileName" class="form-control" />
                            <span asp-validation-for="ProfileName" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="BehavioralInstructions" class="form-label"></label>
                            <textarea asp-for="BehavioralInstructions" class="form-control" rows="6"></textarea>
                            <span asp-validation-for="BehavioralInstructions" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="PrioritySignals" class="form-label"></label>
                            <textarea asp-for="PrioritySignals" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="PrioritySignals" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="ExclusionSignals" class="form-label"></label>
                            <textarea asp-for="ExclusionSignals" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="ExclusionSignals" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="OutputLanguageCode" class="form-label"></label>
                            <select asp-for="OutputLanguageCode" class="form-select">
                                <option value="en">English</option>
                                <option value="fa">فارسی</option>
                            </select>
                            <span asp-validation-for="OutputLanguageCode" class="text-danger small"></span>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary" data-ai-settings-save-button>Save Behavior Settings</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-4">
            <div class="card h-100 app-panel">
                <div class="card-body app-panel-body d-flex flex-column gap-3">
                    <div class="section-label">AI Connection</div>
                    <h2 class="h5">AI Connection</h2>
                    <div class="session-modal-status-stack">
                        <div class="session-status-note @(Model.OpenAiConnectionReady ? "success" : "danger")" data-ai-connection-status-note>
                            @Model.OpenAiConnectionStatusMessage
                        </div>
                        <div class="session-status-note subtle active" data-ai-connection-api-key>
                            <strong>API key:</strong> <span data-ai-connection-api-key-value>@(Model.OpenAiApiKeyConfigured ? "Configured" : "Not configured")</span>
                        </div>
                        <div class="session-status-note subtle active" data-ai-connection-model>
                            <strong>Model:</strong> <span data-ai-connection-model-value>@(string.IsNullOrWhiteSpace(Model.OpenAiModel) ? "Not configured" : Model.OpenAiModel)</span>
                        </div>
                        <div class="session-status-note subtle active" data-ai-connection-base-url>
                            <strong>Base URL:</strong> <span data-ai-connection-base-url-value>@Model.OpenAiBaseUrl</span>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-ai-connection-check>
                            Check Current Readiness
                        </button>
                    </div>
                    <p class="small text-muted mb-0">
                        API keys are not stored in the database. Keep them in <code>dotnet user-secrets</code> or environment variables.
                    </p>
                    <hr />
                    <div class="section-label">What this controls</div>
                    <h2 class="h5">What this controls</h2>
                    <ul class="bullet-list">
                        <li>The tone and priorities used in AI scoring</li>
                        <li>The positive signals that should increase the fit score</li>
                        <li>The mismatch signals that should push jobs toward review or skip</li>
                        <li>The language and reading direction used for AI-generated summaries and rationale</li>
                    </ul>
                    <hr />
                    <p class="small text-muted mb-0">
                        Security settings such as the OpenAI API key, model, and base URL stay outside the database and should be managed through configuration and local secrets.
                    </p>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        (() => {
            const button = document.querySelector("[data-ai-connection-check]");
            const form = document.querySelector("[data-ai-settings-form]");
            const saveButton = document.querySelector("[data-ai-settings-save-button]");
            const statusAlert = document.querySelector("[data-ai-settings-status]");
            const statusNote = document.querySelector("[data-ai-connection-status-note]");
            const apiKeyValue = document.querySelector("[data-ai-connection-api-key-value]");
            const modelValue = document.querySelector("[data-ai-connection-model-value]");
            const baseUrlValue = document.querySelector("[data-ai-connection-base-url-value]");
            const concurrencyTokenInput = document.querySelector('input[name="ConcurrencyToken"]');

            if (!button || !statusNote || !apiKeyValue || !modelValue || !baseUrlValue || !form || !saveButton || !statusAlert) {
                return;
            }

            const setStatus = (message, ready) => {
                statusNote.textContent = message;
                statusNote.classList.remove("success", "danger");
                statusNote.classList.add(ready ? "success" : "danger");
            };

            const tryReadProblem = async (response) => {
                const contentType = response.headers.get("Content-Type") || "";
                if (!contentType.includes("application/problem+json") && !contentType.includes("application/json")) {
                    return null;
                }

                try {
                    return await response.json();
                } catch {
                    return null;
                }
            };

            const setSaveStatus = (message, success) => {
                statusAlert.textContent = message;
                statusAlert.classList.remove("d-none", "alert-success", "alert-warning");
                statusAlert.classList.add(success ? "alert-success" : "alert-warning");
            };

            button.addEventListener("click", async () => {
                const idleText = button.textContent;
                button.disabled = true;
                button.textContent = "Checking...";

                try {
                    const response = await fetch("@Url.Action("ConnectionStatus", "AiSettings")", {
                        headers: {
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        credentials: "same-origin"
                    });

                    const payload = await tryReadProblem(response);

                    if (!response.ok) {
                        setStatus(payload?.detail || payload?.title || "AI connection check failed.", false);
                        return;
                    }

                    if (!payload?.state) {
                        setStatus("AI connection check did not return a usable response.", false);
                        return;
                    }

                    setStatus(payload.message || "OpenAI connection settings are configured and ready for scoring.", !!payload.state.ready);
                    apiKeyValue.textContent = payload.state.apiKeyConfigured ? "Configured" : "Not configured";
                    modelValue.textContent = payload.state.model || "Not configured";
                    baseUrlValue.textContent = payload.state.baseUrl || "https://api.openai.com/v1";
                } catch {
                    setStatus("AI connection check failed.", false);
                } finally {
                    button.disabled = false;
                    button.textContent = idleText;
                }
            });

            form.addEventListener("submit", async (event) => {
                event.preventDefault();

                const idleText = saveButton.textContent;
                saveButton.disabled = true;
                saveButton.textContent = "Saving...";

                try {
                    const response = await fetch(form.action, {
                        method: "POST",
                        body: new FormData(form),
                        headers: {
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        credentials: "same-origin"
                    });

                    const payload = await tryReadProblem(response);

                    if (!response.ok) {
                        setSaveStatus(payload?.detail || payload?.title || "Settings save failed.", false);
                        return;
                    }

                    if (!payload?.success) {
                        setSaveStatus("Settings save did not return a usable response.", false);
                        return;
                    }

                    if (concurrencyTokenInput && payload.concurrencyToken) {
                        concurrencyTokenInput.value = payload.concurrencyToken;
                    }

                    setSaveStatus(payload.message || "AI behavior settings were saved.", true);
                } catch {
                    setSaveStatus("Settings save failed.", false);
                } finally {
                    saveButton.disabled = false;
                    saveButton.textContent = idleText;
                }
            });
        })();
    </script>
}
