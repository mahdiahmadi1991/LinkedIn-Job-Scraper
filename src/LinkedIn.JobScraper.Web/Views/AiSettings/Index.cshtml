@model AiSettingsPageViewModel

@{
    ViewData["Title"] = "AI Settings";
    var alertSeverity = Model.StatusSucceeded ? "success" : "warning";
}

<div class="page-shell">
    <section class="page-hero">
        <div class="section-label mb-2">Scoring Behavior</div>
        <h1 class="hero-title h2">AI Settings</h1>
        <p class="hero-lead">Adjust the behavioral profile used when scoring LinkedIn jobs. API keys stay in configuration, but scoring preferences live here.</p>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-@alertSeverity mb-0" role="alert">
            @Model.StatusMessage
        </div>
    }

    <section class="row g-4">
        <div class="col-12 col-xl-8">
            <div class="card app-panel">
                <div class="card-body app-panel-body">
                    <form asp-action="Save" method="post" class="d-flex flex-column gap-3">
                        @Html.AntiForgeryToken()
                        <div>
                            <label asp-for="ProfileName" class="form-label"></label>
                            <input asp-for="ProfileName" class="form-control" />
                            <span asp-validation-for="ProfileName" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="BehavioralInstructions" class="form-label"></label>
                            <textarea asp-for="BehavioralInstructions" class="form-control" rows="6"></textarea>
                            <span asp-validation-for="BehavioralInstructions" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="PrioritySignals" class="form-label"></label>
                            <textarea asp-for="PrioritySignals" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="PrioritySignals" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="ExclusionSignals" class="form-label"></label>
                            <textarea asp-for="ExclusionSignals" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="ExclusionSignals" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="OutputLanguageCode" class="form-label"></label>
                            <select asp-for="OutputLanguageCode" class="form-select">
                                <option value="en">English</option>
                                <option value="fa">فارسی</option>
                            </select>
                            <span asp-validation-for="OutputLanguageCode" class="text-danger small"></span>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Save Behavior Settings</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-4">
            <div class="card h-100 app-panel">
                <div class="card-body app-panel-body d-flex flex-column gap-3">
                    <div class="section-label">AI Connection</div>
                    <h2 class="h5">AI Connection</h2>
                    <div class="session-modal-status-stack">
                        <div class="session-status-note @(Model.OpenAiConnectionReady ? "success" : "danger")">
                            @Model.OpenAiConnectionStatusMessage
                        </div>
                        <div class="session-status-note subtle active">
                            <strong>API key:</strong> @(Model.OpenAiApiKeyConfigured ? "Configured" : "Not configured")
                        </div>
                        <div class="session-status-note subtle active">
                            <strong>Model:</strong> @(string.IsNullOrWhiteSpace(Model.OpenAiModel) ? "Not configured" : Model.OpenAiModel)
                        </div>
                        <div class="session-status-note subtle active">
                            <strong>Base URL:</strong> @Model.OpenAiBaseUrl
                        </div>
                    </div>
                    <p class="small text-muted mb-0">
                        API keys are not stored in the database. Keep them in <code>dotnet user-secrets</code> or environment variables.
                    </p>
                    <hr />
                    <div class="section-label">What this controls</div>
                    <h2 class="h5">What this controls</h2>
                    <ul class="bullet-list">
                        <li>The tone and priorities used in AI scoring</li>
                        <li>The positive signals that should increase the fit score</li>
                        <li>The mismatch signals that should push jobs toward review or skip</li>
                        <li>The language and reading direction used for AI-generated summaries and rationale</li>
                    </ul>
                    <hr />
                    <p class="small text-muted mb-0">
                        Security settings such as the OpenAI API key, model, and base URL stay outside the database and should be managed through configuration and local secrets.
                    </p>
                </div>
            </div>
        </div>
    </section>
</div>
