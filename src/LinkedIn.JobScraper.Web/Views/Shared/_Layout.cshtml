@using LinkedIn.JobScraper.Web.Authentication
@using LinkedIn.JobScraper.Web.Models
@using LinkedIn.JobScraper.Web.LinkedIn.Session
@using LinkedIn.JobScraper.Web.Versioning
@using System.Globalization
@inject ILinkedInSessionStore LinkedInSessionStore
@inject ILinkedInSessionResetRequirementTracker LinkedInSessionResetRequirementTracker
@inject IAppVersionProvider AppVersionProvider
@{
    LinkedInSessionPageViewModel linkedInSessionViewModel;
    var isSuperAdmin = User.HasClaim(AppUserClaimTypes.IsSuperAdmin, "true");

    try
    {
        var linkedInSessionSnapshot = await LinkedInSessionStore.GetCurrentAsync(Context.RequestAborted);
        var resetRequirement = LinkedInSessionResetRequirementTracker.GetCurrent();

        linkedInSessionViewModel = new LinkedInSessionPageViewModel
        {
            StoredSessionAvailable = linkedInSessionSnapshot is not null,
            StoredSessionCapturedAtUtc = linkedInSessionSnapshot?.CapturedAtUtc,
            StoredSessionSource = linkedInSessionSnapshot?.Source,
            StoredSessionEstimatedExpiresAtUtc = linkedInSessionSnapshot?.EstimatedExpiresAtUtc,
            StoredSessionExpirySource = linkedInSessionSnapshot?.ExpirySource,
            ResetRequired = resetRequirement.Required
        };
    }
    catch (Exception exception)
    {
        linkedInSessionViewModel = new LinkedInSessionPageViewModel
        {
            StatusMessage = $"Session state is unavailable: {exception.Message}",
            StatusSucceeded = false
        };
    }
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LinkedIn.JobScraper.Web</title>
    <meta name="theme-color" content="#0a66c2" />
    <script type="importmap"></script>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" asp-append-version="true" />
    <link rel="alternate icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="manifest" href="~/site.webmanifest" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LinkedIn.JobScraper.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-light app-topbar">
            <div class="container app-shell">
                <a class="navbar-brand d-inline-flex align-items-center" asp-area="" asp-controller="Jobs" asp-action="Index">
                    <span class="brand-mark">in</span>
                    <span>LinkedIn Job Scraper</span>
                </a>
                <div class="app-topbar-actions ms-auto">
                    <div class="session-topbar-slot">
                        <button
                            type="button"
                            class="btn session-indicator-button @linkedInSessionViewModel.SessionIndicatorClass"
                            data-bs-toggle="modal"
                            data-bs-target="#linkedInSessionModal"
                            data-session-indicator
                            aria-label="Open LinkedIn session controls">
                            <span class="session-indicator-dot"></span>
                            <span class="session-indicator-label" data-session-indicator-label>@linkedInSessionViewModel.SessionIndicatorLabel</span>
                        </button>
                    </div>
                    <a class="btn app-topbar-link" asp-area="" asp-controller="AiGlobalShortlist" asp-action="Index">
                        AI Live Review
                    </a>
                    <div class="dropdown app-menu-slot">
                        <button
                            type="button"
                            class="btn app-menu-button"
                            data-bs-toggle="dropdown"
                            data-bs-auto-close="outside"
                            aria-expanded="false"
                            aria-label="Open navigation menu"
                            data-topbar-menu-toggle>
                            <span class="app-menu-button-line"></span>
                            <span class="app-menu-button-line"></span>
                            <span class="app-menu-button-line"></span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end app-menu-dropdown">
                            <li class="dropdown-item-text app-menu-user-label">
                                Signed in as <strong>@(User.Identity?.Name ?? "User")</strong>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <a class="dropdown-item app-menu-item" asp-area="" asp-controller="SearchSettings" asp-action="Index">Search Settings</a>
                            </li>
                            <li>
                                <a class="dropdown-item app-menu-item" asp-area="" asp-controller="AiSettings" asp-action="Index">AI Settings</a>
                            </li>
                            @if (isSuperAdmin)
                            {
                                <li><hr class="dropdown-divider" /></li>
                                <li class="dropdown-item-text app-menu-user-label">Admin</li>
                                <li>
                                    <a class="dropdown-item app-menu-item" asp-area="" asp-controller="Admin" asp-action="Index" asp-route-tab="users">Administration</a>
                                </li>
                            }
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item app-menu-item">Sign out</button>
                                </form>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li class="dropdown-item-text app-menu-version" data-app-menu-version>@AppVersionProvider.CurrentVersion</li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container app-shell">
        <main role="main" class="app-main">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container app-shell">
            <div class="app-footer-content">
                <span>&copy; 2026 - LinkedIn Job Scraper</span>
                <span class="app-version-text" data-app-version>@AppVersionProvider.CurrentVersion</span>
            </div>
        </div>
    </footer>
    <partial name="_LinkedInSessionModal" model="linkedInSessionViewModel" />
    <div class="toast-container position-fixed bottom-0 end-0 p-3 app-toast-stack" data-app-toast-container aria-live="polite" aria-atomic="true"></div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/session-modal.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
