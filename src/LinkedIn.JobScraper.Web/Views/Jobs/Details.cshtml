@model LinkedIn.JobScraper.Web.Jobs.JobDetailsSnapshot

@{
    ViewData["Title"] = "Job Details";
    var fitBadgeClass = Model.AiLabel switch
    {
        "StrongMatch" => "bg-success-subtle text-success-emphasis",
        "Review" => "bg-warning-subtle text-warning-emphasis",
        "Skip" => "bg-secondary-subtle text-secondary-emphasis",
        _ => "bg-light text-dark"
    };
}

<div class="job-details-page page-shell" data-job-ui-root data-job-id="@Model.Id">
    <section class="details-hero p-4 p-xl-5 d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-4">
        <div class="flex-grow-1">
            <div class="section-label mb-2">Opportunity Review</div>
            <div class="mb-3">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Jobs</a>
            </div>
            <h1 class="details-title h2">@Model.Title</h1>
            <div class="details-meta-stack">
                <span class="job-meta-pill">@(Model.CompanyName ?? "Unknown company")</span>
                @if (!string.IsNullOrWhiteSpace(Model.LocationName))
                {
                    <span class="job-meta-pill">@Model.LocationName</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.EmploymentStatus))
                {
                    <span class="job-meta-pill">@Model.EmploymentStatus</span>
                }
            </div>
            <div class="details-context-strip">
                <div class="details-context-item">
                    <span class="details-context-label">Workflow</span>
                    <span class="details-context-value">@Model.CurrentStatus</span>
                </div>
                <div class="details-context-item">
                    <span class="details-context-label">First Seen</span>
                    <span class="details-context-value">@Model.FirstDiscoveredAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                </div>
                <div class="details-context-item">
                    <span class="details-context-label">Last Seen</span>
                    <span class="details-context-value">@Model.LastSeenAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                </div>
            </div>
        </div>
        <div class="details-score-card d-flex flex-column gap-2 align-items-lg-end">
            <span class="badge rounded-pill @fitBadgeClass fs-6" data-job-label-badge>@(Model.AiLabel ?? "Pending")</span>
            <div class="details-fit-score @(Model.AiScore.HasValue ? null : "d-none")" data-job-score-shell><span data-job-score-number>@(Model.AiScore?.ToString() ?? string.Empty)</span><span class="fit-score-muted">/100</span></div>
            <div class="fit-score-muted @(Model.AiScore.HasValue ? "d-none" : null)" data-job-score-empty>Not scored yet</div>
            @if (!string.IsNullOrWhiteSpace(Model.CompanyApplyUrl))
            {
                <a class="btn btn-primary w-100" href="@Model.CompanyApplyUrl" target="_blank" rel="noreferrer">Open Apply</a>
            }
        </div>
    </section>

    <section class="row g-4">
        <div class="col-12 col-xl-4">
            <div class="card details-panel mb-4">
                <div class="card-body">
                    <div class="section-label mb-3">Timeline</div>
                    <div class="details-timeline">
                        <div class="details-timeline-item">
                            <div class="details-timeline-label">Listed</div>
                            <div class="details-timeline-value">
                                @(Model.ListedAtUtc.HasValue
                                    ? Model.ListedAtUtc.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
                                    : "Unknown")
                            </div>
                        </div>
                        <div class="details-timeline-item">
                            <div class="details-timeline-label">First Seen</div>
                            <div class="details-timeline-value">@Model.FirstDiscoveredAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</div>
                        </div>
                        <div class="details-timeline-item">
                            <div class="details-timeline-label">Last Seen</div>
                            <div class="details-timeline-value">@Model.LastSeenAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</div>
                        </div>
                        <div class="details-timeline-item">
                            <div class="details-timeline-label">Workflow Status</div>
                            <div class="details-timeline-value">@Model.CurrentStatus</div>
                        </div>
                        <div class="details-timeline-item">
                            <div class="details-timeline-label">Scored</div>
                            <div class="details-timeline-value" data-job-scored-at-value>
                                @(Model.ScoredAtUtc.HasValue
                                    ? Model.ScoredAtUtc.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
                                    : "Not yet")
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card details-panel">
                <div class="card-body d-flex flex-column gap-3">
                    <div>
                        <div class="section-label mb-2">Actions</div>
                        <h2 class="h6 mb-1">Next Step</h2>
                        <p class="text-muted mb-0">Use this view to decide whether to open the source application flow or keep the role in manual review.</p>
                    </div>
                    <div class="details-action-stack">
                        <form asp-action="ScoreJob" method="post" class="d-grid" data-score-job-form data-job-id="@Model.Id">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="jobId" value="@Model.Id" />
                            <button type="submit"
                                    class="btn btn-outline-primary"
                                    data-score-job-button
                                    data-idle-text="Score This Job"
                                    data-busy-text="Scoring..."
                                    data-done-text="Scored"
                                    data-score-complete="@(Model.AiScore.HasValue && Model.ScoredAtUtc.HasValue ? "true" : "false")"
                                    @(Model.AiScore.HasValue && Model.ScoredAtUtc.HasValue ? "disabled" : null)>
                                <span class="d-none button-loading-shell" data-score-spinner>
                                    <span class="button-loading-spinner" aria-hidden="true"></span>
                                </span>
                                <span data-score-button-text>@(Model.AiScore.HasValue && Model.ScoredAtUtc.HasValue ? "Scored" : "Score This Job")</span>
                            </button>
                        </form>
                        @if (!string.IsNullOrWhiteSpace(Model.CompanyApplyUrl))
                        {
                            <a class="btn btn-primary" href="@Model.CompanyApplyUrl" target="_blank" rel="noreferrer">Open Apply</a>
                        }
                        <a asp-action="Index" class="btn btn-outline-secondary">Back to Jobs</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-8">
            <div class="card h-100 details-panel">
                <div class="card-body d-flex flex-column gap-3">
                    <div>
                        <div class="section-label mb-2">AI Review</div>
                        <h2 class="h5">AI Review</h2>
                        <p class="mb-2 job-summary @(string.IsNullOrWhiteSpace(Model.AiSummary) ? "d-none" : null)"
                           data-job-ai-summary-text
                           dir="auto"
                           lang="@Model.AiOutputLanguageCode">@Model.AiSummary</p>
                        <p class="text-muted mb-2 @(string.IsNullOrWhiteSpace(Model.AiSummary) ? null : "d-none")" data-job-ai-summary-empty>This job has not been scored yet.</p>
                    </div>

                    <div class="details-review-block match @(string.IsNullOrWhiteSpace(Model.AiWhyMatched) ? "d-none" : null)" data-job-why-section>
                        <div class="small text-success fw-semibold text-uppercase mb-1">Why Matched</div>
                        <div data-job-why-text dir="auto" lang="@Model.AiOutputLanguageCode">@Model.AiWhyMatched</div>
                    </div>

                    <div class="details-review-block concern @(string.IsNullOrWhiteSpace(Model.AiConcerns) ? "d-none" : null)" data-job-concerns-section>
                        <div class="small text-warning-emphasis fw-semibold text-uppercase mb-1">Concerns</div>
                        <div data-job-concerns-text dir="auto" lang="@Model.AiOutputLanguageCode">@Model.AiConcerns</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="card details-panel">
        <div class="card-body">
            <div class="section-label mb-2">Source Content</div>
            <h2 class="h5">Job Description</h2>
            <p class="text-muted details-description-note">Stored source text from the LinkedIn job detail payload.</p>
            @if (string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="text-muted mb-0">No description has been captured yet.</p>
            }
            else
            {
                <div class="details-description" dir="auto">@Model.Description</div>
            }
        </div>
    </section>
</div>

@section Scripts
{
    <script src="~/js/jobs-page.js" asp-append-version="true"></script>
}
