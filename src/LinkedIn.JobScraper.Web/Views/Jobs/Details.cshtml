@model LinkedIn.JobScraper.Web.Jobs.JobDetailsSnapshot

@{
    ViewData["Title"] = "Job Details";
    var fitBadgeClass = Model.AiLabel switch
    {
        "StrongMatch" => "bg-success-subtle text-success-emphasis",
        "Review" => "bg-warning-subtle text-warning-emphasis",
        "Skip" => "bg-secondary-subtle text-secondary-emphasis",
        _ => "bg-light text-dark"
    };
}

<div class="d-flex flex-column gap-4">
    <section class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3">
        <div>
            <div class="mb-2">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Jobs</a>
            </div>
            <h1 class="h2 mb-1">@Model.Title</h1>
            <p class="text-muted mb-0">
                @(Model.CompanyName ?? "Unknown company")
                @if (!string.IsNullOrWhiteSpace(Model.LocationName))
                {
                    <span> | @Model.LocationName</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.EmploymentStatus))
                {
                    <span> | @Model.EmploymentStatus</span>
                }
            </p>
        </div>
        <div class="d-flex flex-column gap-2 align-items-lg-end">
            <span class="badge rounded-pill @fitBadgeClass fs-6">@(Model.AiLabel ?? "Pending")</span>
            @if (Model.AiScore.HasValue)
            {
                <div class="fw-semibold">@Model.AiScore / 100</div>
            }
            else
            {
                <div class="text-muted small">Not scored yet</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.CompanyApplyUrl))
            {
                <a class="btn btn-primary" href="@Model.CompanyApplyUrl" target="_blank" rel="noreferrer">Open Apply</a>
            }
        </div>
    </section>

    <section class="row g-4">
        <div class="col-12 col-xl-4">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5">Timeline</h2>
                    <dl class="mb-0">
                        <dt class="small text-muted text-uppercase">Listed</dt>
                        <dd class="mb-3">
                            @(Model.ListedAtUtc.HasValue
                                ? Model.ListedAtUtc.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
                                : "Unknown")
                        </dd>
                        <dt class="small text-muted text-uppercase">First Seen</dt>
                        <dd class="mb-3">@Model.FirstDiscoveredAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</dd>
                        <dt class="small text-muted text-uppercase">Last Seen</dt>
                        <dd class="mb-3">@Model.LastSeenAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</dd>
                        <dt class="small text-muted text-uppercase">Workflow Status</dt>
                        <dd class="mb-0">@Model.CurrentStatus</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-8">
            <div class="card h-100">
                <div class="card-body d-flex flex-column gap-3">
                    <div>
                        <h2 class="h5">AI Review</h2>
                        @if (!string.IsNullOrWhiteSpace(Model.AiSummary))
                        {
                            <p class="mb-2">@Model.AiSummary</p>
                        }
                        else
                        {
                            <p class="text-muted mb-2">This job has not been scored yet.</p>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.AiWhyMatched))
                    {
                        <div>
                            <div class="small text-success fw-semibold text-uppercase">Why Matched</div>
                            <div>@Model.AiWhyMatched</div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.AiConcerns))
                    {
                        <div>
                            <div class="small text-warning-emphasis fw-semibold text-uppercase">Concerns</div>
                            <div>@Model.AiConcerns</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="card">
        <div class="card-body">
            <h2 class="h5">Job Description</h2>
            @if (string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="text-muted mb-0">No description has been captured yet.</p>
            }
            else
            {
                <div class="text-body-secondary" style="white-space: pre-wrap;">@Model.Description</div>
            }
        </div>
    </section>
</div>
