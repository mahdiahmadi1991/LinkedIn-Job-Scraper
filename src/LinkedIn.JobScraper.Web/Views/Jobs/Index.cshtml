@using LinkedIn.JobScraper.Web.Jobs
@using LinkedIn.JobScraper.Web.Persistence.Entities
@model JobsDashboardSnapshot

@{
    ViewData["Title"] = "Jobs";
    var alertMessage = TempData["JobsAlertMessage"] as string;
    var alertSeverity = TempData["JobsAlertSeverity"] as string ?? "info";
    var workflowSummaryAvailable =
        string.Equals(
            TempData["JobsWorkflowSummaryAvailable"] as string,
            bool.TrueString,
            StringComparison.OrdinalIgnoreCase);
    var importFetchedCount = TempData["JobsWorkflowImportFetchedCount"] is int fetchedCount ? fetchedCount : 0;
    var importTotalCount = TempData["JobsWorkflowImportTotalCount"] is int totalCount ? totalCount : 0;
    var importImportedCount = TempData["JobsWorkflowImportImportedCount"] is int importedCount ? importedCount : 0;
    var importRefreshedCount = TempData["JobsWorkflowImportRefreshedCount"] is int refreshedCount ? refreshedCount : 0;
    var importSkippedCount = TempData["JobsWorkflowImportSkippedCount"] is int skippedCount ? skippedCount : 0;
    var enrichmentRequestedCount =
        TempData["JobsWorkflowEnrichmentRequestedCount"] is int enrichmentRequested ? enrichmentRequested : 0;
    var enrichmentProcessedCount =
        TempData["JobsWorkflowEnrichmentProcessedCount"] is int enrichmentProcessed ? enrichmentProcessed : 0;
    var enrichmentEnrichedCount =
        TempData["JobsWorkflowEnrichmentEnrichedCount"] is int enrichmentEnriched ? enrichmentEnriched : 0;
    var enrichmentWarningCount =
        TempData["JobsWorkflowEnrichmentWarningCount"] is int enrichmentWarnings ? enrichmentWarnings : 0;
    var enrichmentFailedCount =
        TempData["JobsWorkflowEnrichmentFailedCount"] is int enrichmentFailed ? enrichmentFailed : 0;
    var scoringRequestedCount =
        TempData["JobsWorkflowScoringRequestedCount"] is int scoringRequested ? scoringRequested : 0;
    var scoringProcessedCount =
        TempData["JobsWorkflowScoringProcessedCount"] is int scoringProcessed ? scoringProcessed : 0;
    var scoringScoredCount =
        TempData["JobsWorkflowScoringScoredCount"] is int scoringScored ? scoringScored : 0;
    var scoringFailedCount =
        TempData["JobsWorkflowScoringFailedCount"] is int scoringFailed ? scoringFailed : 0;
    var query = Model.Query;
    var showSessionRecoveryAction =
        string.Equals(alertSeverity, "danger", StringComparison.OrdinalIgnoreCase) &&
        !string.IsNullOrWhiteSpace(alertMessage) &&
        alertMessage.Contains("LinkedIn Session", StringComparison.OrdinalIgnoreCase);
}

<div class="jobs-page d-flex flex-column gap-4">
    <section class="dashboard-hero p-4 p-xl-5 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-4">
        <div class="dashboard-hero-copy">
            <div class="section-label mb-2">Workflow Console</div>
            <h1 class="h2 mb-1">Jobs Dashboard</h1>
            <p class="dashboard-lead mb-0">Review imported jobs, run the end-to-end fetch flow, and keep manual status current.</p>
        </div>
        <form asp-action="FetchAndScore" method="post" data-fetch-score-form>
            @Html.AntiForgeryToken()
            <input type="hidden" name="Search" value="@query.Search" />
            <input type="hidden" name="FilterStatus" value="@query.FilterStatus" />
            <input type="hidden" name="AiLabel" value="@query.AiLabel" />
            <input type="hidden" name="OnlyUnscored" value="@query.OnlyUnscored" />
            <input type="hidden" name="MinScore" value="@query.MinScore" />
            <input type="hidden" name="SortBy" value="@query.GetNormalizedSortBy()" />
            <button type="submit" class="btn btn-primary btn-lg" data-fetch-score-button>
                <span data-idle-text>Fetch &amp; Score</span>
                <span class="d-none" data-busy-text>Running fetch, enrich, and scoring...</span>
            </button>
        </form>
    </section>

    <section class="card workflow-panel d-none" data-fetch-progress aria-live="polite">
        <div class="card-body d-flex flex-column gap-3">
            <div class="d-flex justify-content-between align-items-center gap-3">
                <div>
                    <div class="section-label">Fetch Workflow</div>
                    <div class="fw-semibold" data-progress-status>Preparing workflow...</div>
                </div>
                <div class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></div>
            </div>
            <div class="progress" role="progressbar" aria-label="Fetch and score progress" aria-valuemin="0" aria-valuemax="100">
                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 8%;" data-progress-bar></div>
            </div>
            <div class="row g-2" data-progress-stages>
                <div class="col-12 col-md-4">
                    <div class="progress-stage p-3" data-progress-stage="0">
                        <div class="small text-muted text-uppercase">Step 1</div>
                        <div class="fw-semibold">Fetch new jobs</div>
                        <div class="small text-body-secondary">Replays the stored LinkedIn search and refreshes what is already known.</div>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="progress-stage p-3" data-progress-stage="1">
                        <div class="small text-muted text-uppercase">Step 2</div>
                        <div class="fw-semibold">Enrich details</div>
                        <div class="small text-body-secondary">Loads richer job detail data for the most relevant incomplete records.</div>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="progress-stage p-3" data-progress-stage="2">
                        <div class="small text-muted text-uppercase">Step 3</div>
                        <div class="fw-semibold">Run AI scoring</div>
                        <div class="small text-body-secondary">Scores ready jobs using the current OpenAI behavior profile.</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(alertMessage))
    {
        <div class="alert alert-@alertSeverity mb-0 d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3" role="alert">
            <span>@alertMessage</span>
            @if (showSessionRecoveryAction)
            {
                <a class="btn btn-sm btn-outline-secondary" asp-controller="LinkedInSession" asp-action="Index">Open LinkedIn Session</a>
            }
        </div>
    }

    @if (workflowSummaryAvailable)
    {
        <section class="card summary-panel">
            <div class="card-body d-flex flex-column gap-3">
                <div>
                    <div class="section-label">Last Workflow Result</div>
                    <div class="fw-semibold">Structured summary of the latest fetch, enrichment, and AI scoring run.</div>
                </div>
                <div class="row g-3">
                    <div class="col-12 col-lg-4">
                        <div class="summary-tile">
                            <div class="small text-muted text-uppercase">Fetch</div>
                            <div class="fw-semibold">@importFetchedCount fetched from @importTotalCount available</div>
                            <div class="small text-body-secondary">@importImportedCount new, @importRefreshedCount refreshed, @importSkippedCount skipped.</div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-4">
                        <div class="summary-tile">
                            <div class="small text-muted text-uppercase">Enrichment</div>
                            <div class="fw-semibold">@enrichmentEnrichedCount enriched out of @enrichmentProcessedCount processed</div>
                            <div class="small text-body-secondary">@enrichmentRequestedCount requested, @enrichmentWarningCount warnings, @enrichmentFailedCount failed.</div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-4">
                        <div class="summary-tile">
                            <div class="small text-muted text-uppercase">AI Scoring</div>
                            <div class="fw-semibold">@scoringScoredCount scored out of @scoringProcessedCount processed</div>
                            <div class="small text-body-secondary">@scoringRequestedCount requested, @scoringFailedCount failed.</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }

    <section class="card filters-panel">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-12 col-xl-4">
                    <label class="form-label" for="Search">Keyword</label>
                    <input class="form-control" type="text" id="Search" name="Search" value="@query.Search" placeholder="Title, company, location, summary" />
                </div>
                <div class="col-6 col-md-3 col-xl-2">
                    <label class="form-label" for="FilterStatus">Status</label>
                    <select class="form-select" id="FilterStatus" name="FilterStatus">
                        <option value="">All</option>
                        @foreach (var status in Enum.GetValues<JobWorkflowStatus>())
                        {
                            <option value="@status" selected="@(query.FilterStatus == status ? "selected" : null)">@status</option>
                        }
                    </select>
                </div>
                <div class="col-6 col-md-3 col-xl-2">
                    <label class="form-label" for="AiLabel">AI Label</label>
                    <select class="form-select" id="AiLabel" name="AiLabel">
                        <option value="">All</option>
                        <option value="StrongMatch" selected="@(query.AiLabel == "StrongMatch" ? "selected" : null)">StrongMatch</option>
                        <option value="Review" selected="@(query.AiLabel == "Review" ? "selected" : null)">Review</option>
                        <option value="Skip" selected="@(query.AiLabel == "Skip" ? "selected" : null)">Skip</option>
                    </select>
                </div>
                <div class="col-6 col-md-3 col-xl-1">
                    <label class="form-label" for="MinScore">Min Score</label>
                    <input class="form-control" type="number" min="0" max="100" id="MinScore" name="MinScore" value="@query.MinScore" />
                </div>
                <div class="col-6 col-md-3 col-xl-2">
                    <label class="form-label" for="SortBy">Sort</label>
                    <select class="form-select" id="SortBy" name="SortBy">
                        <option value="last-seen" selected="@(query.GetNormalizedSortBy() == "last-seen" ? "selected" : null)">Last Seen</option>
                        <option value="listed" selected="@(query.GetNormalizedSortBy() == "listed" ? "selected" : null)">Listed Date</option>
                        <option value="score" selected="@(query.GetNormalizedSortBy() == "score" ? "selected" : null)">AI Score</option>
                        <option value="title" selected="@(query.GetNormalizedSortBy() == "title" ? "selected" : null)">Title</option>
                        <option value="company" selected="@(query.GetNormalizedSortBy() == "company" ? "selected" : null)">Company</option>
                    </select>
                </div>
                <div class="col-12 col-xl-2">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="OnlyUnscored" name="OnlyUnscored" value="true" checked="@query.OnlyUnscored" />
                        <label class="form-check-label" for="OnlyUnscored">Only unscored</label>
                    </div>
                    <input type="hidden" name="OnlyUnscored" value="false" />
                </div>
                <div class="col-12 d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-outline-primary">Apply Filters</button>
                    <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
                    <span class="small text-muted align-self-center">Showing @Model.FilteredJobs of @Model.TotalJobs stored jobs.</span>
                </div>
            </form>
        </div>
    </section>

    <section class="row g-3 stats-panel">
        <div class="col-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body stat-tile">
                    <div class="text-muted small text-uppercase">Total Jobs</div>
                    <div class="stat-value">@Model.TotalJobs</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body stat-tile">
                    <div class="text-muted small text-uppercase">Scored</div>
                    <div class="stat-value">@Model.ScoredJobs</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body stat-tile">
                    <div class="text-muted small text-uppercase">Strong Matches</div>
                    <div class="stat-value">@Model.StrongMatches</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body stat-tile">
                    <div class="text-muted small text-uppercase">Unscored</div>
                    <div class="stat-value">@Model.UnscoredJobs</div>
                </div>
            </div>
        </div>
    </section>

    <section class="card jobs-list-panel">
        <div class="card-body p-0">
            @if (Model.Jobs.Count == 0)
            {
                <div class="empty-state-card">
                    No jobs are stored yet. Capture a LinkedIn session, then run <strong>Fetch &amp; Score</strong>.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle jobs-table">
                        <thead>
                            <tr>
                                <th>Opportunity</th>
                                <th>Fit</th>
                                <th>Workflow</th>
                                <th>Activity</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var job in Model.Jobs)
                        {
                            var fitBadgeClass = job.AiLabel switch
                            {
                                "StrongMatch" => "bg-success-subtle text-success-emphasis",
                                "Review" => "bg-warning-subtle text-warning-emphasis",
                                "Skip" => "bg-secondary-subtle text-secondary-emphasis",
                                _ => "bg-light text-dark"
                            };

                            <tr>
                                <td class="w-50">
                                    <div class="job-opportunity-cell">
                                        <div class="job-title-row">
                                            <span class="job-kicker">Opportunity</span>
                                        </div>
                                        <a asp-action="Details" asp-route-jobId="@job.Id" class="job-title-link">
                                            @job.Title
                                        </a>
                                        <div class="job-meta-wrap">
                                            <span class="job-meta-pill">@(job.CompanyName ?? "Unknown company")</span>
                                            @if (!string.IsNullOrWhiteSpace(job.LocationName))
                                            {
                                                <span class="job-meta-pill">@job.LocationName</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(job.EmploymentStatus))
                                            {
                                                <span class="job-meta-pill">@job.EmploymentStatus</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(job.AiSummary))
                                        {
                                            <div class="job-summary line-clamp-2">
                                                @job.AiSummary
                                            </div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(job.AiWhyMatched) || !string.IsNullOrWhiteSpace(job.AiConcerns))
                                        {
                                            <div class="job-signal-stack">
                                                @if (!string.IsNullOrWhiteSpace(job.AiWhyMatched))
                                                {
                                                    <div class="job-signal-item">
                                                        <span class="job-signal-label match">Match</span>
                                                        <span class="text-body-secondary line-clamp-1">@job.AiWhyMatched</span>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(job.AiConcerns))
                                                {
                                                    <div class="job-signal-item">
                                                        <span class="job-signal-label concern">Concern</span>
                                                        <span class="text-body-secondary line-clamp-1">@job.AiConcerns</span>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="fit-cell">
                                        @if (job.AiScore.HasValue)
                                        {
                                            <div class="fit-score">@job.AiScore<span class="fit-score-muted">/100</span></div>
                                        }
                                        else
                                        {
                                            <div class="fit-score-muted">Not scored</div>
                                        }

                                        <div class="badge rounded-pill @fitBadgeClass fit-label-badge">
                                            @(job.AiLabel ?? "Pending")
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <form asp-action="UpdateStatus" method="post" class="status-form-compact workflow-cell">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="jobId" value="@job.Id" />
                                        <input type="hidden" name="Search" value="@query.Search" />
                                        <input type="hidden" name="FilterStatus" value="@query.FilterStatus" />
                                        <input type="hidden" name="AiLabel" value="@query.AiLabel" />
                                        <input type="hidden" name="OnlyUnscored" value="@query.OnlyUnscored" />
                                        <input type="hidden" name="MinScore" value="@query.MinScore" />
                                        <input type="hidden" name="SortBy" value="@query.GetNormalizedSortBy()" />
                                        <div class="workflow-status-pill">@job.CurrentStatus</div>
                                        <select class="form-select form-select-sm" name="status">
                                            @foreach (var status in Enum.GetValues<JobWorkflowStatus>())
                                            {
                                                <option value="@status" selected="@(status == job.CurrentStatus ? "selected" : null)">
                                                    @status
                                                </option>
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-outline-secondary btn-sm">Save</button>
                                    </form>
                                </td>
                                <td class="small text-muted">
                                    <div class="activity-cell">
                                        <div class="dates-stack">
                                            <div>
                                                <strong>Last Seen</strong>
                                                <span>@job.LastSeenAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                                            </div>
                                            <div>
                                                <strong>Listed</strong>
                                                <span>
                                                    @(job.ListedAtUtc.HasValue
                                                        ? job.ListedAtUtc.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
                                                        : "Unknown")
                                                </span>
                                            </div>
                                        </div>
                                        <div class="apply-actions pt-1">
                                            <a asp-action="Details" asp-route-jobId="@job.Id" class="btn btn-outline-secondary btn-sm">
                                                Open Details
                                            </a>
                                            @if (!string.IsNullOrWhiteSpace(job.CompanyApplyUrl))
                                            {
                                                <a class="btn btn-outline-primary btn-sm" href="@job.CompanyApplyUrl" target="_blank" rel="noreferrer">
                                                    Open Apply
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">No direct apply</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>
</div>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script>
        (() => {
            const form = document.querySelector("[data-fetch-score-form]");
            if (!form) {
                return;
            }

            const button = form.querySelector("[data-fetch-score-button]");
            const idleText = form.querySelector("[data-idle-text]");
            const busyText = form.querySelector("[data-busy-text]");
            const progressPanel = document.querySelector("[data-fetch-progress]");
            const progressBar = document.querySelector("[data-progress-bar]");
            const progressStatus = document.querySelector("[data-progress-status]");
            const stageNodes = Array.from(document.querySelectorAll("[data-progress-stage]"));
            const stageOrder = ["fetch", "enrichment", "scoring"];
            let signalRConnection = null;
            let isSubmitting = false;

            const setBusyState = () => {
                if (button) {
                    button.disabled = true;
                }

                if (idleText) {
                    idleText.classList.add("d-none");
                }

                if (busyText) {
                    busyText.classList.remove("d-none");
                }

                if (progressPanel) {
                    progressPanel.classList.remove("d-none");
                }
            };

            const setIdleState = () => {
                if (button) {
                    button.disabled = false;
                }

                if (idleText) {
                    idleText.classList.remove("d-none");
                }

                if (busyText) {
                    busyText.classList.add("d-none");
                }
            };

            const applyProgressUpdate = (update) => {
                if (!update) {
                    return;
                }

                if (progressPanel) {
                    progressPanel.classList.remove("d-none");
                }

                if (progressStatus && update.message) {
                    progressStatus.textContent = update.message;
                }

                if (progressBar) {
                    const percent = Math.max(0, Math.min(100, Number(update.percent) || 0));
                    progressBar.style.width = `${percent}%`;
                    progressBar.setAttribute("aria-valuenow", String(percent));
                    progressBar.classList.toggle("progress-bar-animated", update.state === "running");
                    progressBar.classList.toggle("progress-bar-striped", update.state === "running");
                    progressBar.classList.toggle("bg-warning", update.state === "warning");
                    progressBar.classList.toggle("bg-danger", update.state === "failed");
                    progressBar.classList.toggle("bg-success", update.state === "completed");
                }

                const activeIndex = stageOrder.indexOf(update.stage);

                stageNodes.forEach((node, currentIndex) => {
                    const isActive = currentIndex === activeIndex;
                    const isCompleted = activeIndex > currentIndex || update.stage === "completed";

                    node.classList.toggle("border-primary", isActive);
                    node.classList.toggle("bg-primary-subtle", isActive);
                    node.classList.toggle("text-primary-emphasis", isActive);
                    node.classList.toggle("border-success", !isActive && isCompleted);
                    node.classList.toggle("bg-success-subtle", !isActive && isCompleted);
                    node.classList.toggle("text-success-emphasis", !isActive && isCompleted);
                });
            };

            const ensureConnection = async () => {
                if (!window.signalR) {
                    return null;
                }

                if (signalRConnection && signalRConnection.state === "Connected") {
                    return signalRConnection;
                }

                signalRConnection = new signalR.HubConnectionBuilder()
                    .withUrl("/hubs/jobs-workflow-progress")
                    .withAutomaticReconnect()
                    .build();

                signalRConnection.on("WorkflowProgress", (update) => {
                    applyProgressUpdate(update);
                });

                await signalRConnection.start();
                return signalRConnection;
            };

            form.addEventListener("submit", async (event) => {
                if (isSubmitting) {
                    event.preventDefault();
                    return;
                }

                let connection = null;

                try {
                    connection = await ensureConnection();
                } catch {
                    connection = null;
                }

                if (!connection || !connection.connectionId) {
                    setBusyState();
                    return;
                }

                event.preventDefault();
                isSubmitting = true;
                setBusyState();
                applyProgressUpdate({
                    state: "running",
                    stage: "fetch",
                    percent: 6,
                    message: "Starting Fetch & Score workflow..."
                });

                try {
                    const response = await fetch(form.action, {
                        method: "POST",
                        headers: {
                            "X-Requested-With": "XMLHttpRequest",
                            "X-Progress-ConnectionId": connection.connectionId
                        },
                        body: new FormData(form),
                        credentials: "same-origin"
                    });

                    const payload = await response.json();

                    if (!response.ok || !payload || !payload.redirectUrl) {
                        throw new Error(payload?.message || "Fetch & Score request failed.");
                    }

                    window.setTimeout(() => {
                        window.location.assign(payload.redirectUrl);
                    }, 250);
                } catch (error) {
                    applyProgressUpdate({
                        state: "failed",
                        stage: "completed",
                        percent: 100,
                        message: error instanceof Error ? error.message : "Fetch & Score request failed."
                    });
                    isSubmitting = false;
                    setIdleState();
                }
            });
        })();
    </script>
}
