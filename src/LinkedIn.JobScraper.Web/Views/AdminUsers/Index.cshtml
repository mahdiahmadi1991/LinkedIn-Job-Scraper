@model LinkedIn.JobScraper.Web.Models.AdminUsersPageViewModel
@{
    ViewData["Title"] = "User Management";
}

<div class="page-shell">
    <section class="page-hero">
        <div class="section-label mb-2">Administration</div>
        <h1 class="hero-title h2">User Management</h1>
        <p class="hero-lead">
            Create local users and review current accounts. This section is restricted to the super-admin account.
        </p>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert @(Model.StatusSucceeded ? "alert-success" : "alert-danger")" role="status">
            @Model.StatusMessage
        </div>
    }

    <section class="row g-4">
        <div class="col-12 col-xl-4">
            <div class="card app-panel">
                <div class="card-body app-panel-body">
                    <h2 class="h5 mb-3">Create User</h2>
                    <form asp-action="Create" method="post" class="d-flex flex-column gap-3">
                        @Html.AntiForgeryToken()

                        <div>
                            <label asp-for="CreateForm.UserName" class="form-label"></label>
                            <input asp-for="CreateForm.UserName" class="form-control" autocomplete="username" />
                            <span asp-validation-for="CreateForm.UserName" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="CreateForm.DisplayName" class="form-label"></label>
                            <input asp-for="CreateForm.DisplayName" class="form-control" />
                            <span asp-validation-for="CreateForm.DisplayName" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="CreateForm.Password" class="form-label"></label>
                            <input asp-for="CreateForm.Password" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="CreateForm.Password" class="text-danger small"></span>
                        </div>

                        <div class="form-check form-switch">
                            <input asp-for="CreateForm.IsActive" class="form-check-input" />
                            <label asp-for="CreateForm.IsActive" class="form-check-label"></label>
                        </div>

                        <div>
                            <label asp-for="CreateForm.ExpiresAtUtc" class="form-label"></label>
                            <input asp-for="CreateForm.ExpiresAtUtc" class="form-control" type="datetime-local" />
                            <span asp-validation-for="CreateForm.ExpiresAtUtc" class="text-danger small"></span>
                            <div class="small text-muted mt-1">Leave empty for no expiry.</div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Create User</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-8">
            <div class="card app-panel">
                <div class="card-body app-panel-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">Current Users</h2>
                        <span class="small text-muted">Total: @Model.Users.Count</span>
                    </div>

                    @if (Model.Users.Count == 0)
                    {
                        <p class="text-muted mb-0">No users are currently stored.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th scope="col">Id</th>
                                        <th scope="col">Username</th>
                                        <th scope="col">Display Name</th>
                                        <th scope="col">Flags</th>
                                        <th scope="col">Expires</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in Model.Users)
                                    {
                                        <tr>
                                            <td>@user.Id</td>
                                            <td>@user.UserName</td>
                                            <td>@user.DisplayName</td>
                                            <td>
                                                <span class="badge @(user.IsActive ? "text-bg-success" : "text-bg-secondary") me-1">
                                                    @(user.IsActive ? "Active" : "Inactive")
                                                </span>
                                                @if (user.IsSuperAdmin)
                                                {
                                                    <span class="badge text-bg-primary">Super Admin</span>
                                                }
                                            </td>
                                            <td>@(user.ExpiresAtUtc?.ToString("yyyy-MM-dd HH:mm 'UTC'") ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
</div>
