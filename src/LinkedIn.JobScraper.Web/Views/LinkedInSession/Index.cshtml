@model LinkedIn.JobScraper.Web.Models.LinkedInSessionPageViewModel

@{
    ViewData["Title"] = "LinkedIn Session";
}

<div class="page-shell">
    <section class="page-hero">
        <div class="section-label mb-2">Authentication Flow</div>
        <h1 class="hero-title h2">LinkedIn Session</h1>
        <p class="hero-lead">
            Launch a controlled browser and complete LinkedIn login manually. The app now watches for a successful login and tries to capture the authenticated session automatically.
        </p>
    </section>

    <div class="row g-4">
        <div class="col-12 col-xl-8">
            <p class="text-muted mb-0">
                Launch a controlled browser and complete LinkedIn login manually. The app now watches for a successful login and tries to capture the authenticated session automatically.
            </p>

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="alert @(Model.StatusSucceeded ? "alert-success" : "alert-danger")" role="alert">
                    @Model.StatusMessage
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.AutoCaptureStatusMessage))
            {
                <div class="alert @(Model.AutoCaptureActive ? "alert-primary" : "alert-secondary")" role="alert">
                    @Model.AutoCaptureStatusMessage
                </div>
            }

            @if (!Model.StoredSessionAvailable && !Model.AutoCaptureActive)
            {
                <div class="alert alert-warning" role="alert">
                    No active LinkedIn session is available. If your last session expired, launch the browser again and let auto-capture save a fresh session.
                </div>
            }

            <div class="card app-panel mb-4">
                <div class="card-body app-panel-body">
                    <div class="section-label mb-3">Current State</div>
                    <div class="state-grid">
                        <div class="state-grid-row">
                            <div class="state-grid-label">Browser Open</div>
                            <div class="state-grid-value">@(Model.BrowserOpen ? "Yes" : "No")</div>
                        </div>
                        <div class="state-grid-row">
                            <div class="state-grid-label">Current Page</div>
                            <div class="state-grid-value">@(Model.CurrentPageUrl ?? "Not available")</div>
                        </div>
                        <div class="state-grid-row">
                            <div class="state-grid-label">Stored Session</div>
                            <div class="state-grid-value">@(Model.StoredSessionAvailable ? "Available" : "Not captured yet")</div>
                        </div>
                        <div class="state-grid-row">
                            <div class="state-grid-label">Captured At</div>
                            <div class="state-grid-value">@(Model.StoredSessionCapturedAtUtc?.ToString("u") ?? "Not available")</div>
                        </div>
                        <div class="state-grid-row">
                            <div class="state-grid-label">Session Source</div>
                            <div class="state-grid-value">@(Model.StoredSessionSource ?? "Not available")</div>
                        </div>
                        <div class="state-grid-row">
                            <div class="state-grid-label">Auto-Capture</div>
                            <div class="state-grid-value">@(Model.AutoCaptureActive ? "Watching for login" : "Idle")</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="stacked-actions">
                <form asp-action="Launch" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">Launch Login Browser</button>
                </form>

                <form asp-action="Capture" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-primary">Capture Session</button>
                </form>

                <form asp-action="Verify" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary">Verify Stored Session</button>
                </form>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="card h-100 app-panel">
                <div class="card-body app-panel-body">
                    <div class="section-label mb-3">What to expect</div>
                    <ul class="bullet-list">
                        <li>Use <strong>Launch Login Browser</strong> and finish the LinkedIn login in the controlled browser window.</li>
                        <li>Auto-capture should save the session as soon as the required cookies are present.</li>
                        <li><strong>Capture Session</strong> remains available as a manual fallback if the watcher does not complete.</li>
                        <li><strong>Verify Stored Session</strong> runs a lightweight authenticated check instead of a full job search.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
